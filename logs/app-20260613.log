    SELECT u.id, u.created_at, u.deleted_at, u.remarks, u.status, u.updated_at, u.user_id, u.verified_by
    FROM user_verifications AS u
    WHERE u.user_id = @userId
    ORDER BY u.created_at DESC
    LIMIT 1
) AS u1
LEFT JOIN (
    SELECT u0.user_verification_id, u0.document_id, d.id, d.created_at, d.deleted_at, d.document_number, d.document_type_id, d.document_url, d.updated_at
    FROM user_verification_documents AS u0
    INNER JOIN documents AS d ON u0.document_id = d.id
) AS s ON u1.id = s.user_verification_id
ORDER BY u1.created_at DESC, u1.id, s.user_verification_id, s.document_id
